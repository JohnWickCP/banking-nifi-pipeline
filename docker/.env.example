# ─── Banking NiFi Pipeline — Docker environment variables ───────────────────
# Copy this file to .env (same directory) and update values as needed.
# Default values already work for local development — only change if there
# are port conflicts or you want stronger credentials.
#
#   cp docker/.env.example docker/.env
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=banking_dw
POSTGRES_USER=banking
POSTGRES_PASSWORD=banking123
POSTGRES_HOST_PORT=5432

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_HOST_PORT=9092

# ── Apache NiFi ──────────────────────────────────────────────────────────────
# Password must be 12+ chars with uppercase, lowercase, digit, and special char
NIFI_USERNAME=admin
NIFI_PASSWORD=Banking@Admin1
NIFI_JVM_HEAP_INIT=1g
NIFI_JVM_HEAP_MAX=2g
NIFI_HOST_PORT=8443

# ── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123
GRAFANA_HOST_PORT=3000
