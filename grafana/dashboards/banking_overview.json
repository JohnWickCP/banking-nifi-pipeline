{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Banking Multi-channel Transaction Pipeline — Real-time Overview",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "id": 1,
      "title": "Total Transactions",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM fact_txn",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Fraud Alerts (Total)",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM fact_alert",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Fraud Rate (%)",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "mappings": [],
          "unit": "percent",
          "decimals": 2
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawSql": "SELECT ROUND(100.0 * COUNT(*) FILTER (WHERE fraud_flag = true) / NULLIF(COUNT(*), 0), 2) AS value FROM fact_txn",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Avg Alert Latency (s)",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          },
          "mappings": [],
          "unit": "s",
          "decimals": 2
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawSql": "SELECT ROUND(EXTRACT(EPOCH FROM AVG(created_at - detected_at))::numeric, 2) AS value FROM fact_alert WHERE detected_at > NOW() - INTERVAL '1 hour'",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "id": 5,
      "title": "Clean Transactions",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM fact_txn WHERE fraud_flag = false",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "id": 6,
      "title": "PII Masking Violations",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM fact_txn WHERE account_masked NOT LIKE '****%'",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 10,
      "title": "Transaction Volume — Last Hour (per minute)",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 4 },
      "options": {
        "legend": { "calcs": ["sum", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "format": "time_series",
          "rawSql": "SELECT date_trunc('minute', loaded_at) AS time, COUNT(*) AS \"All Transactions\" FROM fact_txn WHERE loaded_at > NOW() - INTERVAL '1 hour' GROUP BY 1 ORDER BY 1",
          "refId": "A"
        },
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "format": "time_series",
          "rawSql": "SELECT date_trunc('minute', loaded_at) AS time, COUNT(*) AS \"Fraud\" FROM fact_txn WHERE fraud_flag = true AND loaded_at > NOW() - INTERVAL '1 hour' GROUP BY 1 ORDER BY 1",
          "refId": "B"
        }
      ]
    },
    {
      "type": "piechart",
      "id": 11,
      "title": "Fraud Alerts by Rule",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["value"] },
        "pieType": "donut",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawSql": "SELECT rule_triggered AS metric, COUNT(*) AS value FROM fact_alert GROUP BY rule_triggered ORDER BY value DESC",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "id": 20,
      "title": "Recent Fraud Alerts",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "options": {
        "showHeader": true,
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "severity" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "HIGH":   { "color": "red",    "index": 0 } } },
                  { "type": "value", "options": { "MEDIUM": { "color": "orange", "index": 1 } } },
                  { "type": "value", "options": { "LOW":    { "color": "green",  "index": 2 } } }
                ]
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawSql": "SELECT alert_id, transaction_id, rule_triggered, severity, detected_at FROM fact_alert ORDER BY detected_at DESC LIMIT 20",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "id": 21,
      "title": "Transaction Volume by Channel",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 12 },
      "options": { "showHeader": true },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawSql": "SELECT channel, COUNT(*) AS total, COUNT(*) FILTER (WHERE fraud_flag) AS fraud, ROUND(100.0 * COUNT(*) FILTER (WHERE fraud_flag) / NULLIF(COUNT(*), 0), 2) AS fraud_pct FROM fact_txn GROUP BY channel ORDER BY total DESC",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "id": 22,
      "title": "Top 10 Merchants by Fraud",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 12 },
      "options": { "showHeader": true },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawSql": "SELECT merchant_id, merchant_province, COUNT(*) AS fraud_count FROM fact_txn WHERE fraud_flag = true GROUP BY merchant_id, merchant_province ORDER BY fraud_count DESC LIMIT 10",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["banking", "fraud", "nifi", "realtime"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 2,
        "includeAll": false,
        "multi": false,
        "name": "DS_POSTGRES",
        "options": [],
        "query": "postgres",
        "refresh": 1,
        "type": "datasource",
        "label": "PostgreSQL"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Banking Pipeline — Real-time Overview",
  "uid": "banking-pipeline-overview",
  "version": 1
}
